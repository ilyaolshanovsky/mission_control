## gigachat | openai
LLM_PROVIDER=gigachat

## GigaChat
GIGACHAT_CREDENTIALS=put_your_base64_here
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_SSL=false

## OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2500

## Google Sheets (автообновление данных)
# Ссылка на CSV-экспорт листа «Кампусы» (gviz работает для таблиц по ссылке):
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/gviz/tq?tqx=out:csv&sheet=1
GOOGLE_SHEET_CSV_URL=
# Интервал синхронизации в секундах (по умолчанию 300 = 5 минут)
SHEET_SYNC_INTERVAL_SEC=300

## Поиск в интернете для Ольги
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
# false — если корпоративный прокси ломает SSL (как GIGACHAT_VERIFY_SSL)
WEB_SEARCH_VERIFY_SSL=true
